# Database (Railway sẽ cung cấp khi thêm MySQL add-on)
DATABASE_URL="mysql://user:password@host:port/database"

# JWT Secret (đổi thành chuỗi bí mật của bạn)
JWT_SECRET="your-super-secret-jwt-key-here"

# Port (Railway tự gán, không cần set)
# PORT=4000

# Client URL (chỉ cần nếu deploy client riêng, không cần nếu serve từ API)
# CLIENT_URL="https://your-app.up.railway.app"

# Frontend URL (dùng cho link reset password trong email)
FRONTEND_URL="https://your-app.up.railway.app"

# Uploads directory (Railway Volume mount path)
UPLOADS_DIR="/data/uploads"
