generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  createBy      Admin?   @relation("CreatedAdmins", fields: [createById], references: [id])
  createById    Int?
  createdAdmins Admin[]  @relation("CreatedAdmins")
  createAt      DateTime @default(now())
  updateAt      DateTime @updatedAt
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  email            String         @unique
  password         String?
  avatar           String?
  phone            String?
  zalo             String?
  createAt         DateTime       @default(now())
  updateAt         DateTime       @updatedAt
  places           Place[]        @relation("UserPlaces")
  bookings         Booking[]      @relation("UserBookings")
  reports          Report[]       @relation("UserReports")
  status           String         @default("ACTIVE") // ACTIVE | BLACKLISTED | DEACTIVATED
  violationCount   Int            @default(0)
  comments         Comment[]      @relation("UserComments")
  favourites       Favourite[]    @relation("UserFavs")
  notifications    Notification[] @relation("UserNotis")
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Report {
  id         Int      @id @default(autoincrement())
  reporter   User     @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId Int
  place      Place    @relation("PlaceReports", fields: [placeId], references: [id], onDelete: Cascade)
  placeId    Int
  reason     String
  status     String   @default("PENDING") // PENDING | DONE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Place {
  id           Int            @id @default(autoincrement())
  owner        User           @relation("UserPlaces", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      Int
  title        String
  address      String
  latitude     Decimal?
  longitude    Decimal?
  area         Int
  photos       PlacePhoto[]   @relation("PlacePhotos")
  description  String
  perks        PlacePerk[]    @relation("PlacePerks")
  extraInfo    String
  duration     Int
  price        Float
  status       String         @default("SEE") // SEE | HIDDEN | DELETE
  bookings     Booking[]      @relation("PlaceBookings")
  reports      Report[]       @relation("PlaceReports")
  favourites   Favourite[]    @relation("PlaceFavs")
  notification Notification[] @relation("PlaceNotis")
  createAt     DateTime       @default(now())
  updateAt     DateTime       @updatedAt
}

model PlacePhoto {
  id      Int    @id @default(autoincrement())
  url     String
  place   Place  @relation("PlacePhotos", fields: [placeId], references: [id], onDelete: Cascade)
  placeId Int
}

model PlacePerk {
  id      String @id @default(uuid())
  perk    String
  place   Place  @relation("PlacePerks", fields: [placeId], references: [id], onDelete: Cascade)
  placeId Int
}

model Booking {
  id         Int       @id @default(autoincrement())
  place      Place     @relation("PlaceBookings", fields: [placeId], references: [id], onDelete: Cascade)
  placeId    Int
  renter     User      @relation("UserBookings", fields: [renterId], references: [id], onDelete: Cascade)
  renterId   Int
  checkOut   DateTime?
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED | WAIT | RENTED
  isContinue Boolean   @default(false)
  invoices   Invoice[] @relation("BookingInvoices")
  comments   Comment[] @relation("BookingComments")
  createAt   DateTime  @default(now())
  updateAt   DateTime  @updatedAt
}

model Invoice {
  id          Int            @id @default(autoincrement())
  booking     Booking        @relation("BookingInvoices", fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   Int
  title       String
  description String?
  photos      InvoicePhoto[] @relation("InvoicePhotos")
  createdAt   DateTime       @default(now())
  updateAt    DateTime       @updatedAt
}

model InvoicePhoto {
  id        Int     @id @default(autoincrement())
  url       String
  invoice   Invoice @relation("InvoicePhotos", fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId Int
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  bookingId Int      @unique
  user      User     @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking  @relation("BookingComments", fields: [bookingId], references: [id], onDelete: Cascade)
}

model Favourite {
  id        Int      @id @default(autoincrement())
  userId    Int
  placeId   Int
  user      User     @relation("UserFavs", fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation("PlaceFavs", fields: [placeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, placeId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("UserNotis", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  placeId   Int?
  place     Place?   @relation("PlaceNotis", fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, type, createdAt])
}
